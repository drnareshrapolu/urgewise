{
  "name": "urgewise",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "node --experimental-strip-types server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "start": "node --experimental-strip-types server/index.ts",
    "test": "node --experimental-strip-types tests/run-tests.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.59.0",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.1.5",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.14",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "supertest": "^7.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
